{
  "policies": [
    {
      "id": "rate-1s-compat",
      "name": "Rate limit 1/s backwards compat (D defaults to 1)",
      "log": {
        "match": [
          {
            "resource_attribute": "service.name",
            "exact": "api-server"
          }
        ],
        "keep": "1/s"
      }
    }
  ]
}
