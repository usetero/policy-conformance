{
  "policies": [
    {
      "id": "redact-account-id-braced",
      "name": "Redact account id with braced capture reference",
      "log": {
        "match": [
          { "log_field": "body", "contains": "account_" }
        ],
        "keep": "all",
        "transform": {
          "redact": [
            {
              "log_field": "body",
              "regex": "(account_)([0-9]+)",
              "replacement": "${1}[REDACTED]"
            }
          ]
        }
      }
    }
  ]
}
